extends ../layout

block content

    .d-flex.justify-content-between.align-items-center.mb-4

        div
            h3.mb-1 Employee Master
            p.text-muted.mb-0 Manage company employees

        button.btn.btn-primary(
            type="button"
            data-bs-toggle="modal"
            data-bs-target="#employeeModal"
        )
            i.bi.bi-plus-lg.me-2
            | Add Employee

    .card.shadow-sm

        .card-body

            .row.g-3.mb-3.align-items-center

                .col-md-5

                    input.form-control#searchEmployee(
                        type="text"
                        placeholder="Search employee..."
                    )

                .col-md-3

                    select.form-select#statusFilter

                        option(value="") All Employees
                        option(value="Active") Active
                        option(value="Inactive") Inactive

            .table-responsive

                table.table.table-striped.table-hover.align-middle#employeeTable

                    thead.table-dark

                        tr
                            th Code
                            th Name
                            th Email
                            th Mobile
                            th Department
                            th Designation
                            th Joining Date
                            th Status
                            th.text-center Action

                    include _table

    include _add_edit_modal
    include _view_modal

block scripts
    script(src="/js/employee.js")