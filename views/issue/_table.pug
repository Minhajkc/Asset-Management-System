.card
    .card-body

        table.table.table-bordered.table-hover#issueTable
            thead.table-dark
                tr
                    th Employee
                    th Asset
                    th Quantity
                    th Issue Date
                    th Status
                    th Actions

            tbody
                each issue in issues
                    tr
                        td= issue.Employee.employee_name
                        td= issue.Asset.asset_name
                        td= issue.quantity
                        td= issue.issue_date

                        td
                            if issue.status === "Issued"
                                span.badge.bg-warning.text-dark Issued
                            else
                                span.badge.bg-success Returned

                        td
                            button.btn.btn-sm.btn-info.me-1.view-btn(
                                type="button"
                                data-id=issue.id
                                data-employee=issue.Employee.employee_name
                                data-asset=issue.Asset.asset_name
                                data-quantity=issue.quantity
                                data-date=issue.issue_date
                                data-status=issue.status
                                data-remarks=issue.remarks
                            )
                                i.bi.bi-eye

                            button.btn.btn-sm.btn-warning.me-1.edit-btn(
                                type="button"
                                data-id=issue.id
                                data-employee-id=issue.employee_id
                                data-asset-id=issue.asset_id
                                data-quantity=issue.quantity
                                data-date=issue.issue_date
                                data-status=issue.status
                                data-remarks=issue.remarks
                            )
                                i.bi.bi-pencil

                            form.d-inline(
                                action="/issue_asset/delete/" + issue.id
                                method="POST"
                            )
                                button.btn.btn-sm.btn-danger(
                                    type="submit"
                                    onclick="return confirm('Delete this issue record?')"
                                )
                                    i.bi.bi-trash