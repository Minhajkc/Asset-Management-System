.card
    .card-body

        table.table.table-bordered.table-hover#categoryTable
            thead.table-dark
                tr
                    th ID
                    th Category Name
                    th Description
                    th Status
                    th Actions

            tbody
                each category in categories
                    tr
                        td= category.id
                        td= category.category_name
                        td= category.description
                        td
                            if category.status === "Active"
                                span.badge.bg-success Active
                            else
                                span.badge.bg-secondary Inactive

                        td
                            button.btn.btn-sm.btn-info.me-1.view-btn(
                                type="button"
                                data-id=category.id
                                data-name=category.category_name
                                data-description=category.description
                                data-status=category.status
                            )
                                i.bi.bi-eye

                            button.btn.btn-sm.btn-warning.me-1.edit-btn(
                                type="button"
                                data-id=category.id
                                data-name=category.category_name
                                data-description=category.description
                                data-status=category.status
                            )
                                i.bi.bi-pencil

                            form.d-inline(
                                action="/asset_categories/delete/" + category.id
                                method="POST"
                            )
                                button.btn.btn-sm.btn-danger(
                                    type="submit"
                                    onclick="return confirm('sure you want to delete ')"
                                )
                                    i.bi.bi-trash