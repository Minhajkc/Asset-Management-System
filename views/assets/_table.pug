.card
    .card-body
        table.table.table-bordered.table-hover#assetTable
            thead.table-dark
                tr
                    th Code
                    th Asset Name
                    th Category
                    th Brand
                    th Quantity
                    th Status
                    th Actions

            tbody
                each asset in assets
                    tr
                        td= asset.asset_code
                        td= asset.asset_name
                        td= asset.Category ? asset.Category.category_name : "-"
                        td= asset.brand

                        td= asset.quantity

                        td
                            if asset.status === "Active"
                                span.badge.bg-success Active
                            else
                                span.badge.bg-secondary Inactive

                        td
                          
                            button.btn.btn-sm.btn-info.me-1.view-btn(
                                type="button"
                                data-id=asset.id
                                data-code=asset.asset_code
                                data-name=asset.asset_name
                                data-category=asset.category_id
                                data-categoryname=asset.Category ? asset.Category.category_name : "-"
                                data-branch=asset.branch
                                data-brand=asset.brand
                                data-model=asset.model
                                data-serial=asset.serial_number
                                data-date=asset.purchase_date
                                data-cost=asset.purchase_cost
                                data-quantity=asset.quantity
                                data-status=asset.status
                            )
                                i.bi.bi-eye

                      
                                button.btn.btn-sm.btn-warning.me-1.edit-btn(
                                    type="button"
                                    data-id=asset.id
                                    data-code=asset.asset_code
                                    data-name=asset.asset_name
                                    data-category=asset.category_id
                                    data-branch=asset.branch
                                    data-brand=asset.brand
                                    data-model=asset.model
                                    data-serial=asset.serial_number
                                    data-date=asset.purchase_date
                                    data-cost=asset.purchase_cost
                                    data-quantity=asset.quantity
                                    data-status=asset.status
                                )
                                    i.bi.bi-pencil

                                form.d-inline(
                                    action="/asset_master/delete/" + asset.id
                                    method="POST"
                                )
                                    button.btn.btn-sm.btn-danger(
                                        type="submit"
                                        onclick="return confirm('Delete this asset?')"
                                    )
                                        i.bi.bi-trash